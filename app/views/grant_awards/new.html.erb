<% content_for :title, "Add grant or award" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Grants & Awards", grant_awards_path %></li>
          <li class="breadcrumb-item active" aria-current="page">Add item</li>
        </ol>
      </nav>

      <h1 class="mb-2">Add a grant or award</h1>
      <p class="text-muted mb-4">Record a research grant, teaching award, or other recognition to display on your portfolio.</p>

      <%= render "form", grant_award: @grant_award %>

    </div>
  </div>
</div>
