
<%= simple_form_for(@grant_award) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%= f.input :title %>
    <%= f.input :description %>
    <%= f.input :year %>
    <%= f.input :awarding_body %>
    <%= f.input :category %>
    <%= f.input :slug %>
    <%= f.input :featured,
          label: "Featured item",
          hint: "Featured items are shown in the Portfolio homepage and highlighted with a star on the Grants & Awards page." %>
  </div>

  <div class="form-actions">
    <%= f.button :submit %>
  </div>
<% end %>
