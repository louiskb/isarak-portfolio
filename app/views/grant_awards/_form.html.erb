
<%= simple_form_for(@grant_award, html: { data: {
  controller: "publish-form load-button",
  "publish-form-current-status-value": (@grant_award.status || "draft")
} }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%= f.input :title,
          placeholder: "e.g. ARC Discovery Project Grant",
          hint: "The full name of the grant or award as it should appear on your portfolio." %>

    <%= f.input :category,
          label: "Type",
          as: :select,
          collection: GrantAward.categories.keys.map { |k| [k.capitalize, k] },
          hint: "Select Grant for funding you received, or Award for recognition of your work." %>

    <%= f.input :awarding_body,
          label: "Awarding body / Funder",
          placeholder: "e.g. Australian Research Council",
          hint: "The organisation that granted the funding or presented the award." %>

    <%= f.input :year,
          placeholder: "e.g. 2023 or 2021–2023",
          hint: "The year the grant was awarded or the award was received." %>

    <%= f.input :description,
          label: "Description (optional)",
          hint: "Briefly describe the scope, value, or significance of this grant or award.",
          as: :text,
          input_html: { rows: 4 } %>

  </div>

  <%# Hidden fields — controlled by the split button via the publish-form Stimulus controller %>
  <input type="hidden"
         name="grant_award[status]"
         value="<%= @grant_award.status || "draft" %>"
         data-publish-form-target="statusInput">
  <input type="hidden"
         name="grant_award[scheduled_at]"
         value="<%= @grant_award.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
         data-publish-form-target="scheduledAtInput">

  <%# ===== SPLIT PUBLISH BUTTON ===== %>
  <div class="form-actions d-flex align-items-center gap-3 flex-wrap mt-4" data-load-button-target="buttons">
    <% if @grant_award.persisted? %>
      <% if @grant_award.scheduled? %>
        <p class="small text-warning w-100 mb-1">
          <i class="fa-regular fa-clock me-1"></i>
          Scheduled to publish on <%= @grant_award.scheduled_at.strftime("%d %b %Y at %H:%M") %>
          &mdash; use the dropdown to change status.
        </p>
      <% elsif @grant_award.published? %>
        <p class="small text-success w-100 mb-1">
          <i class="fa-solid fa-circle-check me-1"></i>
          This entry is published and visible on the homepage
          &mdash; use the dropdown to change status.
        </p>
      <% else %>
        <p class="small text-muted w-100 mb-1">
          <i class="fa-regular fa-file-lines"></i>
          This entry is a draft and not shown on the homepage
          &mdash; use the dropdown to change status.
        </p>
      <% end %>
    <% end %>
    <div class="btn-group dropup">
      <% if @grant_award.new_record? %>
        <button type="button" class="btn btn-blog-publish btn-publish-main"
                data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                data-load-button-loading-text-value="Saving...">
          Save as draft
        </button>
      <% else %>
        <button type="button" class="btn btn-blog-publish btn-publish-main"
                data-action="click->load-button#showSpinner click->publish-form#saveChanges"
                data-load-button-loading-text-value="Saving changes...">
          Save changes
        </button>
      <% end %>

      <button type="button"
              class="btn btn-blog-publish btn-publish-chevron dropdown-toggle dropdown-toggle-split"
              data-bs-toggle="dropdown"
              aria-expanded="false">
        <span class="visually-hidden">More publishing options</span>
      </button>

      <ul class="dropdown-menu dropdown-menu-end">
        <% unless @grant_award.new_record? %>
          <li>
            <button type="button" class="dropdown-item"
                    data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                    data-load-button-loading-text-value="Saving...">
              <i class="fa-regular fa-file me-2 text-muted"></i>Save as draft
            </button>
          </li>
          <li><hr class="dropdown-divider"></li>
        <% end %>
        <li>
          <button type="button" class="dropdown-item"
                  data-action="click->load-button#showSpinner click->publish-form#publishNow"
                  data-load-button-loading-text-value="Publishing...">
            <i class="fa-solid fa-globe me-2 text-muted"></i>Publish now
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item"
                  data-bs-toggle="modal" data-bs-target="#schedulePostModal">
            <i class="fa-regular fa-clock me-2 text-muted"></i>Schedule&hellip;
          </button>
        </li>
      </ul>
    </div>
  </div>

  <%# ===== SCHEDULE MODAL ===== %>
  <div class="modal fade" id="schedulePostModal" tabindex="-1"
       aria-labelledby="schedulePostModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="schedulePostModalLabel">
            <i class="fa-regular fa-clock me-2"></i>Schedule entry
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted mb-3">Choose when this entry will appear on the homepage automatically.</p>
          <label class="form-label fw-semibold" for="schedule-post-datetime">Publish at</label>
          <input type="datetime-local"
                 id="schedule-post-datetime"
                 class="form-control"
                 min="<%= Time.current.strftime("%Y-%m-%dT%H:%M") %>"
                 value="<%= @grant_award.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
                 data-publish-form-target="scheduleInput"
                 required>
          <div class="form-text"><i class="fa-solid fa-clock me-1"></i>Times are in <strong><%= Time.current.zone %></strong> (Sydney).</div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-blog-publish"
                  data-action="click->load-button#showSpinner click->publish-form#confirmSchedule"
                  data-load-button-loading-text-value="Scheduling...">
            Schedule
          </button>
        </div>
      </div>
    </div>
  </div>

<% end %>
