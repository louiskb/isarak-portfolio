<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Isarak Portfolio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Isarak Portfolio">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="google-site-verification" content="_HxXeRLj1BEMXpYPiLGUQDtNO37UMG3CK2ZLQCoClVo">

    <%# Open Graph / social sharing meta tags — overridden per-page via content_for :meta_tags %>
    <% unless content_for?(:meta_tags) %>
      <meta property="og:site_name" content="Dr Isara Khanjanasthiti">
      <meta property="og:title" content="Dr Isara Khanjanasthiti — Urban Planner, Educator, Researcher">
      <meta property="og:description" content="Urban Planner, Educator, Researcher in Aviation, Housing and Teaching &amp; Learning. University of New England, Sydney campus.">
      <meta property="og:url" content="<%= request.url %>">
      <meta property="og:type" content="website">
      <meta property="og:image" content="<%= image_url("ik-logo-tp.png") %>">
      <meta name="twitter:card" content="summary">
      <meta name="twitter:title" content="Dr Isara Khanjanasthiti — Urban Planner, Educator, Researcher">
      <meta name="twitter:description" content="Urban Planner, Educator, Researcher in Aviation, Housing and Teaching &amp; Learning. University of New England, Sydney campus.">
    <% end %>
    <%= yield :meta_tags %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "ik-logo-tp.png", type: "image/png" %>
    <%= tag.link rel: "apple-touch-icon", href: image_path("ik-logo-tp.png") %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= content_for(:body_class) %>">

    <header data-controller="navbar-height">
      <%= render "shared/navbar" %>
    </header>

    <main>
      <%= render "shared/flashes" %>
      <%= yield %>
    </main>

    <footer>
      <%= render "shared/footer" %>
    </footer>

    <button class="btn btn-primary back-to-top"
            data-controller="back-to-top"
            data-action="click->back-to-top#scrollToTop"
            aria-label="Back to top">
      <i class="fa-solid fa-chevron-up"></i>
    </button>

  </body>
</html>
