<% content_for :title, "Teaching — Isara Khanjanasthiti" %>

<%# ===== HERO ===== %>
<section class="resource-hero">
  <div class="container">
    <div class="resource-hero-inner">
      <p class="resource-hero-label">Education</p>
      <h1 class="resource-hero-title">Teaching</h1>
      <p class="resource-hero-subtitle">
        Courses taught, subjects coordinated, and academic teaching experience.
      </p>
      <% if user_signed_in? %>
        <p class="resource-hero-subtitle resource-hero-info mt-2">
          <i class="fa-solid fa-star me-1" style="color: #facc15;"></i>Tick <strong>`Featured`</strong> on an item to include it in the homepage Teaching spotlight — <span class="hi-teaching">max 3 shown, most recently updated first</span>. If you feature more than 3, the most recently edited items take priority. <span class="hi-teaching">Drag reorders this page only</span> — it does not affect the homepage.
        </p>
        <div class="mt-4">
          <%= link_to "Add Teaching", new_teaching_path, class: "btn btn-resource-add" %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== GRID ===== %>
<section class="resource-grid-section">
  <div class="container">
    <% if @teachings.any? %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4"
           <% if user_signed_in? %>data-controller="sortable" data-sortable-url-value="<%= reorder_teachings_path %>"<% end %>>
        <% @teachings.each do |item| %>
          <div class="col" data-id="<%= item.id %>">
            <article class="resource-card card">
              <% if user_signed_in? %>
                <div class="drag-handle" title="Drag to reorder">
                  <i class="fa-solid fa-grip-vertical"></i>
                </div>
              <% end %>
              <% if item.image.attached? %>
                <%= image_tag item.image, class: "resource-card-img", alt: item.title %>
              <% elsif item.image_url.present? %>
                <img src="<%= item.image_url %>" class="resource-card-img" alt="<%= item.title %>">
              <% end %>
              <div class="card-body">
                <h2 class="resource-card-title"><%= item.title %></h2>

                <% if item.institution.present? || item.year.present? %>
                  <p class="resource-card-meta">
                    <% if item.institution.present? %>
                      <i class="fa-solid fa-graduation-cap me-1"></i><%= item.institution %>
                    <% end %>
                    <% if item.institution.present? && item.year.present? %> &middot; <% end %>
                    <% if item.year.present? %><%= item.year %><% end %>
                    <% if item.featured? %>&nbsp;<i class="fa-solid fa-star ms-1" title="Featured"></i><% end %>
                  </p>
                <% end %>

                <% if item.description.present? %>
                  <p class="resource-card-description"><%= item.description %></p>
                <% end %>

                <% if user_signed_in? %>
                  <div class="d-flex justify-content-end align-items-center resource-card-footer">
                    <%= link_to "Manage →", teaching_path(item), class: "btn btn-resource-manage btn-sm" %>
                  </div>
                <% end %>
              </div>
            </article>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="resource-empty text-center">
        <p class="text-muted mb-3">No teaching entries yet.</p>
        <%= link_to "Add your first entry", new_teaching_path, class: "btn btn-resource-add" %>
      </div>
    <% end %>

    <div class="mt-5">
      <%= raw @pagy.series_nav(:bootstrap) if @pagy.pages > 1 %>
    </div>
  </div>
</section>
