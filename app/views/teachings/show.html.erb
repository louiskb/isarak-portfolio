<% content_for :title, "#{@teaching.title} — Teaching" %>

<div class="resource-detail">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <nav aria-label="breadcrumb" class="mb-4">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Teaching", teachings_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @teaching.title %></li>
          </ol>
        </nav>

        <%= render "shared/flashes" %>

        <article>
          <div class="resource-detail-header">
            <h1 class="resource-detail-title"><%= @teaching.title %></h1>

            <div class="resource-detail-meta">
              <% if @teaching.institution.present? %>
                <span>
                  <i class="fa-solid fa-graduation-cap me-1"></i>
                  <%= @teaching.institution %>
                </span>
              <% end %>
              <% if @teaching.year.present? %>
                <span>
                  <i class="fa-regular fa-calendar me-1"></i>
                  <%= @teaching.year %>
                </span>
              <% end %>
              <% if @teaching.featured? %>
                <span class="resource-featured-badge">
                  <i class="fa-solid fa-star me-1"></i>Featured
                </span>
              <% end %>
            </div>
          </div>

          <% if @teaching.description.present? %>
            <div class="resource-detail-description">
              <%= simple_format @teaching.description %>
            </div>
          <% end %>

          <% if @teaching.image_url.present? %>
            <div class="mt-4">
              <%= image_tag @teaching.image_url,
                    alt: @teaching.title,
                    class: "img-fluid rounded",
                    style: "max-height: 360px; object-fit: cover; width: 100%;" %>
            </div>
          <% end %>
        </article>

        <%# Admin actions %>
        <div class="resource-detail-actions">
          <%= link_to "Edit", edit_teaching_path(@teaching), class: "btn btn-resource-edit" %>
          <%= button_to "Delete", @teaching,
                method: :delete,
                class: "btn btn-resource-delete",
                data: { turbo_confirm: "Delete \"#{@teaching.title}\"? This cannot be undone." } %>
        </div>

      </div>
    </div>
  </div>
</div>
