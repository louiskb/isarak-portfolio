
<%= simple_form_for(@teaching, html: { multipart: true, data: {
  controller: "publish-form load-button",
  "publish-form-current-status-value": (@teaching.status || "draft")
} }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%# <div class="alert alert-info small mb-4">
      <i class="fa-solid fa-circle-info me-1"></i>
      <strong>Heads up:</strong> The title and description appear on the homepage teaching card alongside the image.
      Keep them concise so the text fits neatly within the card.
    </div> %>

    <%# <div data-controller="char-counter" data-char-counter-limit-value="80"> %>
    <%= f.input :title,
          placeholder: "e.g. Urban Planning Studio, PLAN3001",
          hint: "The course name or teaching role as it should appear on your portfolio." %>
    <%# <span class="form-text small mt-n2 d-block mb-3" data-char-counter-target="display"></span> %>
    <%# </div> %>

    <%# <div data-controller="char-counter" data-char-counter-limit-value="60"> %>
    <%= f.input :institution,
          label: "Institution",
          placeholder: "e.g. University of New England",
          hint: "The university or organisation where this teaching took place. Shown in the card footer." %>
    <%# <span class="form-text small mt-n2 d-block mb-3" data-char-counter-target="display"></span> %>
    <%# </div> %>

    <%# <div data-controller="char-counter" data-char-counter-limit-value="20"> %>
    <%= f.input :year,
          as: :string,
          placeholder: "e.g. 2024 or 2023–Present",
          hint: "The year or year range this course was delivered." %>
    <%# <span class="form-text small mt-n2 d-block mb-3" data-char-counter-target="display"></span> %>
    <%# </div> %>

    <%= f.input :card_summary,
          label: "Card summary",
          as: :text,
          input_html: { rows: 2 },
          hint: "A short 1–2 sentence preview shown on index and homepage cards." %>

    <%# <div data-controller="char-counter" data-char-counter-limit-value="250"> %>
    <%= f.input :description,
          label: "Description",
          hint: "The full description of the course content and your teaching role. Shown on the public show page.",
          as: :text,
          input_html: { rows: 4 } %>
    <%# <span class="form-text small mt-n2 d-block mb-3" data-char-counter-target="display"></span> %>
    <%# </div> %>

    <%= f.input :image,
          as: :file,
          label: "Course image (optional)",
          hint: "Upload a JPG or PNG. Shown on the homepage spotlight. Overrides the image URL below if both are set.",
          input_html: { accept: "image/*", class: "form-control form-control-dark" } %>
    <% if f.object.persisted? && f.object.image.attached? %>
      <% attached_url = url_for(f.object.image) rescue nil %>
      <% if attached_url %>
        <div class="mb-3">
          <p class="profile-input-hint mb-1">Current uploaded image:</p>
          <%= link_to attached_url, target: "_blank", rel: "noopener noreferrer" do %>
            <%= image_tag attached_url, class: "img-fluid rounded", style: "max-height: 160px; object-fit: cover;" %>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%= f.input :image_url,
          label: "Course image URL (optional)",
          placeholder: "https://example.com/image.jpg",
          hint: "Fallback if no image is uploaded above." %>
    <% if f.object.persisted? && f.object.image_url.present? %>
      <div class="mb-3">
        <p class="profile-input-hint mb-1">Current image URL:</p>
        <%= link_to f.object.image_url, target: "_blank", rel: "noopener noreferrer" do %>
          <%= image_tag f.object.image_url, class: "img-fluid rounded", style: "max-height: 160px; object-fit: cover;" %>
        <% end %>
      </div>
    <% end %>

    <%= f.input :external_url,
          label: "External link (optional)",
          placeholder: "https://example.com/course-page",
          hint: "A link to more information — e.g. a course page or unit guide. Shown as \"More Information\" on the public page." %>

    <%= f.input :featured,
          label: "Featured item",
          hint: "Featured items appear in the Teaching section on the homepage — max 3 shown, most recently updated first. Drag order applies on the Teaching index page only." %>
  </div>

  <%# Hidden fields — controlled by the split button via the publish-form Stimulus controller %>
  <input type="hidden"
         name="teaching[status]"
         value="<%= @teaching.status || "draft" %>"
         data-publish-form-target="statusInput">
  <input type="hidden"
         name="teaching[scheduled_at]"
         value="<%= @teaching.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
         data-publish-form-target="scheduledAtInput">

  <%# ===== SPLIT PUBLISH BUTTON ===== %>
  <div class="form-actions d-flex align-items-center gap-3 flex-wrap mt-4" data-load-button-target="buttons">
    <% if @teaching.persisted? %>
      <% if @teaching.scheduled? %>
        <p class="small text-warning w-100 mb-1">
          <i class="fa-regular fa-clock me-1"></i>
          Scheduled to publish on <%= @teaching.scheduled_at.strftime("%d %b %Y at %H:%M") %>
          &mdash; use the dropdown to change status.
        </p>
      <% elsif @teaching.published? %>
        <p class="small text-success w-100 mb-1">
          <i class="fa-solid fa-circle-check me-1"></i>
          This entry is published and visible to everyone
          &mdash; use the dropdown to change status.
        </p>
      <% else %>
        <p class="small text-muted w-100 mb-1">
          <i class="fa-regular fa-file-lines"></i>
          This entry is a draft and not visible to visitors
          &mdash; use the dropdown to change status.
        </p>
      <% end %>
    <% end %>
    <div class="btn-group dropup">
      <% if @teaching.new_record? %>
        <button type="button" class="btn btn-blog-publish btn-publish-main"
                data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                data-load-button-loading-text-value="Saving...">
          Save as draft
        </button>
      <% else %>
        <button type="button" class="btn btn-blog-publish btn-publish-main"
                data-action="click->load-button#showSpinner click->publish-form#saveChanges"
                data-load-button-loading-text-value="Saving changes...">
          Save changes
        </button>
      <% end %>

      <button type="button"
              class="btn btn-blog-publish btn-publish-chevron dropdown-toggle dropdown-toggle-split"
              data-bs-toggle="dropdown"
              aria-expanded="false">
        <span class="visually-hidden">More publishing options</span>
      </button>

      <ul class="dropdown-menu dropdown-menu-end">
        <% unless @teaching.new_record? %>
          <li>
            <button type="button" class="dropdown-item"
                    data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                    data-load-button-loading-text-value="Saving...">
              <i class="fa-regular fa-file me-2 text-muted"></i>Save as draft
            </button>
          </li>
          <li><hr class="dropdown-divider"></li>
        <% end %>
        <li>
          <button type="button" class="dropdown-item"
                  data-action="click->load-button#showSpinner click->publish-form#publishNow"
                  data-load-button-loading-text-value="Publishing...">
            <i class="fa-solid fa-globe me-2 text-muted"></i>Publish now
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item"
                  data-bs-toggle="modal" data-bs-target="#schedulePostModal">
            <i class="fa-regular fa-clock me-2 text-muted"></i>Schedule&hellip;
          </button>
        </li>
      </ul>
    </div>
  </div>

  <%# ===== SCHEDULE MODAL ===== %>
  <div class="modal fade" id="schedulePostModal" tabindex="-1"
       aria-labelledby="schedulePostModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="schedulePostModalLabel">
            <i class="fa-regular fa-clock me-2"></i>Schedule teaching entry
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted mb-3">Choose when this entry will go live automatically.</p>
          <label class="form-label fw-semibold" for="schedule-post-datetime">Publish at</label>
          <input type="datetime-local"
                 id="schedule-post-datetime"
                 class="form-control"
                 min="<%= Time.current.strftime("%Y-%m-%dT%H:%M") %>"
                 value="<%= @teaching.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
                 data-publish-form-target="scheduleInput"
                 required>
          <div class="form-text"><i class="fa-solid fa-clock me-1"></i>Times are in <strong><%= Time.current.zone %></strong> (Sydney).</div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-blog-publish"
                  data-action="click->load-button#showSpinner click->publish-form#confirmSchedule"
                  data-load-button-loading-text-value="Scheduling...">
            Schedule
          </button>
        </div>
      </div>
    </div>
  </div>

<% end %>
