
<%= simple_form_for(@teaching, html: { multipart: true, data: { controller: "load-button" } }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%= f.input :title,
          placeholder: "e.g. Urban Planning Studio, PLAN3001",
          hint: "The course name or teaching role as it should appear on your portfolio." %>

    <%= f.input :institution,
          label: "Institution",
          placeholder: "e.g. University of New England",
          hint: "The university or organisation where this teaching took place." %>

    <%= f.input :year,
          placeholder: "e.g. 2024 or 2022–2024",
          hint: "The year or year range this course was delivered." %>

    <%= f.input :description,
          label: "Description",
          hint: "Summarise the course content and your teaching role. Shown as a blurb on your Teaching page.",
          as: :text,
          input_html: { rows: 4 } %>

    <%= f.input :image,
          as: :file,
          label: "Course image (optional)",
          hint: "Upload a JPG or PNG. Shown on the homepage spotlight. Overrides the image URL below if both are set.",
          input_html: { accept: "image/*", class: "form-control form-control-dark" } %>

    <%= f.input :image_url,
          label: "Course image URL (optional)",
          placeholder: "https://example.com/image.jpg",
          hint: "Fallback if no image is uploaded above." %>

    <%= f.input :featured,
          label: "Featured item",
          hint: "Featured items are highlighted on your Portfolio homepage. Tick this for courses you want to showcase prominently." %>
  </div>

  <div class="form-actions" data-load-button-target="buttons">
    <%= f.button :submit, class: "btn btn-resource-add rounded-4",
          data: { action: "click->load-button#showSpinner",
                  load_button_loading_text_value: "Saving..." } %>
  </div>
<% end %>
