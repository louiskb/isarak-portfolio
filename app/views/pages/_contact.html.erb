<%# Contact section — anchored for navbar "Contact Me" CTA link %>
<section id="contact" class="home-contact" data-controller="scroll-reveal">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8" data-scroll-reveal-target="fadeIn">
        <p class="home-section-label">Contact</p>
        <h2 class="home-section-title mb-3">Get in Touch</h2>
        <p class="home-contact-sub mb-5">
          Interested in collaborating on research or have a question? Fill out the form below
          or email me directly at
          <%= link_to "isarapd@icloud.com", "mailto:isarapd@icloud.com", class: "home-contact-email-link" %>.
        </p>

        <%# Contact form %>
        <%= simple_form_for @contact,
            url: contacts_path,
            local: true,
            data: { controller: "load-button", turbo: false },
            class: "mb-2" do |f| %>
          <%= f.error_notification %>
          <div class="row">
            <div class="col-12 col-md-6">
              <%= f.input :first_name, label: "First Name" %>
            </div>
            <div class="col-12 col-md-6">
              <%= f.input :last_name, label: "Last Name" %>
            </div>
          </div>
          <%= f.input :email, label: "Your Email" %>
          <%= f.input :message, as: :text, rows: 6, label: "Message" %>
          <%# Honeypot spam protection %>
          <%= invisible_captcha %>
          <div data-load-button-target="buttons" class="mt-4 mb-4">
            <button type="button"
                    class="btn btn-grad"
                    data-action="click->load-button#loader"
                    data-load-button-loading-text-value="Sending message...">
              Send Message
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
