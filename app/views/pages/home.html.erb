<% content_for :title, "Dr Isara Khanjanasthiti — Urban Planner, Educator & Researcher" %>
<% content_for :body_class, "page-home" %>

<%# ===== HERO ===== %>
<section class="home-hero" data-controller="video-hero">

  <%# Scroll-scrubbed time lapse video — day → sunset → night as user scrolls.
      Falls back to static background-image if video fails or is unsupported.
      For production: host on Cloudinary for CDN delivery and update the src. %>
  <video class="home-hero-video"
         data-video-hero-target="video"
         muted
         playsinline
         preload="auto"
         aria-hidden="true">
    <source src="/videos/airport-sunset-night-time-lapse.mp4" type="video/mp4">
  </video>

  <div class="home-hero-overlay"></div>

  <div class="container position-relative home-hero-container">

    <%# Top left — name, subtitle, CTAs %>
    <div class="home-hero-top">
      <h1 class="home-hero-title">
        Dr Isara<br>Khanjanasthiti
      </h1>
      <p class="home-hero-subtitle">
        Aviation policy, housing governance, and university teaching &amp; learning
        at the University of New England, Sydney.
      </p>
      <div class="home-hero-ctas">
        <a href="#contact" class="btn btn-grad">Contact Me</a>
        <%= link_to "View Research", research_items_path, class: "btn home-btn-outline" %>
      </div>
    </div>

    <%# Bottom row — socials left, tags right %>
    <div class="home-hero-bottom">
      <div class="home-hero-socials">
        <a href="#" class="home-hero-social-link" aria-label="LinkedIn" target="_blank" rel="noopener">
          <i class="fa-brands fa-linkedin"></i>
        </a>
        <a href="mailto:isara@example.com" class="home-hero-social-link" aria-label="Email">
          <i class="fa-solid fa-envelope"></i>
        </a>
        <a href="#" class="home-hero-social-link" aria-label="Twitter / X" target="_blank" rel="noopener">
          <i class="fa-brands fa-x-twitter"></i>
        </a>
      </div>
      <%# Desktop: center item in the bottom row (space-between puts it between socials + tags) %>
      <%# Mobile: order 3 pushes it below tags (order 2) via CSS %>
      <a href="#about" class="home-hero-scroll-hint" aria-label="Scroll to About">
        <i class="fa-solid fa-chevron-down"></i>
      </a>

      <div class="home-hero-tags">
        <span class="home-hero-tag">Urban Planner</span>
        <span class="home-hero-tag">Educator</span>
        <span class="home-hero-tag">Researcher</span>
      </div>
    </div>

  </div>
</section>

<%# ===== ABOUT ===== %>
<section class="home-about" id="about" data-controller="scroll-reveal">
  <div class="container">
    <div class="row align-items-start g-4 g-lg-5">

      <%# Left — photo + quick facts %>
      <div class="col-lg-5" data-scroll-reveal-target="fromLeft">
        <div class="home-about-photo-wrap">
          <% if @isara&.avatar&.attached? %>
            <%= image_tag @isara.avatar, class: "home-about-photo", alt: "Dr Isara Khanjanasthiti" %>
          <% else %>
            <div class="home-about-photo-placeholder">
              <i class="fa-solid fa-user"></i>
            </div>
          <% end %>
        </div>

        <div class="home-about-sidebar mt-4">
          <div class="home-about-fact">
            <i class="fa-solid fa-graduation-cap home-about-fact-icon"></i>
            <div>
              <p class="home-about-fact-label">Institution</p>
              <p class="home-about-fact-value">University of New England, Sydney Campus</p>
            </div>
          </div>
          <div class="home-about-fact">
            <i class="fa-solid fa-location-dot home-about-fact-icon"></i>
            <div>
              <p class="home-about-fact-label">Based in</p>
              <p class="home-about-fact-value">Sydney, Australia</p>
            </div>
          </div>
          <div class="home-about-fact">
            <i class="fa-solid fa-magnifying-glass home-about-fact-icon"></i>
            <div>
              <p class="home-about-fact-label">Research Focus</p>
              <p class="home-about-fact-value">Aviation, Housing, Urban & Regional Planning</p>
            </div>
          </div>
          <div class="home-about-fact">
            <i class="fa-solid fa-earth-asia home-about-fact-icon"></i>
            <div>
              <p class="home-about-fact-label">Background</p>
              <p class="home-about-fact-value">Bangkok, Thailand &rarr; Sydney, Australia</p>
            </div>
          </div>
          <div class="home-about-fact">
            <i class="fa-regular fa-envelope home-about-fact-icon"></i>
            <div>
              <p class="home-about-fact-label">Email</p>
              <p class="home-about-fact-value">
                <a href="#contact" class="home-about-fact-link">Send a message &darr;</a>
              </p>
            </div>
          </div>
        </div>
      </div>

      <%# Right — bio, tags, CV download %>
      <div class="col-lg-7" data-scroll-reveal-target="fromRight">
        <p class="home-section-label">About Me</p>
        <h2 class="home-section-title mb-4">Urban planner with a<br>global perspective</h2>

        <div class="home-about-bio">
          <% if @isara&.about.present? %>
            <div class="home-about-text trix-content">
              <%= @isara.about %>
            </div>
          <% else %>
            <p class="home-about-text">
              I am an urban and regional planning academic at the University of New England (UNE),
              based at the Sydney campus. My doctoral research examined economic development and
              cross-border planning around second-tier airports through a case study of
              Gold Coast Airport.
            </p>
            <p class="home-about-text">
              Born in Bangkok, Thailand, and now calling Sydney home, my research interests span
              aviation policy, cross-border governance, housing, and university teaching and learning.
            </p>
          <% end %>
        </div>

        <div class="home-about-tags mt-4">
          <span class="home-tag">Aviation Policy</span>
          <span class="home-tag">Housing Governance</span>
          <span class="home-tag">Urban & Regional Planning</span>
          <span class="home-tag">Cross-border Governance</span>
          <span class="home-tag">University Teaching & Learning</span>
        </div>

        <% if @isara&.cv&.attached? %>
          <div class="mt-4">
            <%= link_to "Download CV", download_cv_path, class: "btn home-btn-outline" %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</section>

<%# ===== FEATURED TEACHING SPOTLIGHT ===== %>
<% if @featured_teachings.any? %>
  <section class="home-section" id="teaching" data-controller="teaching-spotlight scroll-reveal">
    <div class="container">

      <%# Header row %>
      <div class="d-flex justify-content-between align-items-end mb-4 mb-md-5">
        <div>
          <p class="home-section-label">Education</p>
          <h2 class="home-section-title">Teaching</h2>
        </div>
        <%= link_to "View all &rarr;".html_safe, teachings_path, class: "home-section-viewall" %>
      </div>

      <%# Spotlight — card left, image right %>
      <div class="row g-4 g-lg-5 align-items-stretch" data-scroll-reveal-target="fromBottom">

        <%# Left: stacked text cards %>
        <div class="col-lg-5">
          <div class="teaching-spotlight-cards">
            <% @featured_teachings.each_with_index do |item, i| %>
              <div class="teaching-spotlight-card <%= i == 0 ? "is-active" : "" %>"
                   data-teaching-spotlight-target="card"
                   data-index="<%= i %>">

                <div class="teaching-spotlight-card-body">
                  <p class="home-section-label mb-2">
                    <i class="fa-solid fa-chalkboard-user me-1"></i> Course
                  </p>
                  <h3 class="teaching-spotlight-title"><%= item.title %></h3>
                  <% if item.description.present? %>
                    <p class="teaching-spotlight-desc"><%= item.description %></p>
                  <% end %>
                </div>

                <div class="teaching-spotlight-card-footer">
                  <div class="teaching-spotlight-meta">
                    <% if item.institution.present? %>
                      <p class="teaching-spotlight-meta-primary"><%= item.institution %></p>
                    <% end %>
                    <% if item.year.present? %>
                      <p class="teaching-spotlight-meta-secondary"><%= item.year %></p>
                    <% end %>
                  </div>
                  <% if @featured_teachings.size > 1 %>
                    <div class="teaching-spotlight-arrows">
                      <button class="awards-slider-btn" data-action="click->teaching-spotlight#prev" aria-label="Previous">
                        <i class="fa-solid fa-arrow-left"></i>
                      </button>
                      <button class="awards-slider-btn" data-action="click->teaching-spotlight#next" aria-label="Next">
                        <i class="fa-solid fa-arrow-right"></i>
                      </button>
                    </div>
                  <% end %>
                </div>

              </div>
            <% end %>
          </div>
        </div>

        <%# Right: stacked images %>
        <div class="col-lg-7">
          <div class="teaching-spotlight-images">
            <% @featured_teachings.each_with_index do |item, i| %>
              <div class="teaching-spotlight-image-panel <%= i == 0 ? "is-active" : "" %>"
                   data-teaching-spotlight-target="image"
                   data-index="<%= i %>">
                <% if item.image.attached? %>
                  <%= image_tag item.image, class: "teaching-spotlight-img", alt: item.title %>
                <% elsif item.image_url.present? %>
                  <img src="<%= item.image_url %>" class="teaching-spotlight-img" alt="<%= item.title %>">
                <% else %>
                  <div class="teaching-spotlight-img-placeholder">
                    <i class="fa-solid fa-chalkboard"></i>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

      </div>

      <%# Bottom pills — one per teaching %>
      <% if @featured_teachings.size > 1 %>
        <div class="teaching-spotlight-pills mt-5">
          <% @featured_teachings.each_with_index do |item, i| %>
            <button class="teaching-spotlight-pill <%= i == 0 ? "is-active" : "" %>"
                    data-teaching-spotlight-target="pill"
                    data-action="click->teaching-spotlight#select"
                    data-index="<%= i %>">
              <%= truncate(item.title, length: 40) %>
            </button>
          <% end %>
        </div>
      <% end %>

    </div>
  </section>
<% end %>

<%# ===== FEATURED RESEARCH ===== %>
<% if @featured_research.any? %>
  <section class="home-section" id="research" data-controller="scroll-reveal">
    <div class="container">
      <div class="d-flex justify-content-between align-items-end mb-4 mb-md-5">
        <div>
          <p class="home-section-label">Research</p>
          <h2 class="home-section-title">Research &amp; Publications</h2>
        </div>
        <%= link_to "View all &rarr;".html_safe, research_items_path, class: "home-section-viewall" %>
      </div>

      <div class="row g-3">
        <% @featured_research.each do |item| %>
          <div class="col-12 col-md-6" data-scroll-reveal-target="fromBottom">
            <% img_src = item.image.attached? ? (url_for(item.image) rescue nil) : item.image_url.presence %>
            <article class="research-grid-card" style="<%= img_src ? "background-image: url('#{img_src}');" : "" %>">
              <div class="research-grid-card-body">
                <h3 class="research-grid-card-title"><%= item.title %></h3>
                <% if item.published_at.present? %>
                  <p class="research-grid-card-date"><%= item.published_at.strftime("%B %Y") %></p>
                <% end %>
                <% if item.external_url.present? %>
                  <%= link_to item.external_url, class: "research-grid-card-arrow",
                        target: "_blank", rel: "noopener noreferrer" do %>
                    <i class="fa-solid fa-arrow-right"></i>
                  <% end %>
                <% end %>
              </div>
            </article>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ===== SERVICE ===== %>
<% if @service&.description.present? %>
  <section class="home-section" id="service" data-controller="scroll-reveal">
    <div class="container">
      <div class="d-flex justify-content-between align-items-end mb-4 mb-md-5">
        <div>
          <p class="home-section-label">Academic Service</p>
          <h2 class="home-section-title">Service</h2>
        </div>
        <% if user_signed_in? %>
          <%= link_to "View service &rarr;".html_safe, edit_service_path, class: "home-section-viewall" %>
        <% end %>
      </div>
      <div class="home-about-text trix-content" data-scroll-reveal-target="fadeIn">
        <%= @service.description %>
      </div>
    </div>
  </section>
<% end %>

<%# ===== FEATURED GRANTS & AWARDS SLIDER ===== %>
<% if @featured_grants.any? %>
  <section class="home-section" id="awards" data-controller="awards-slider scroll-reveal">
    <div class="container">
      <div class="d-flex justify-content-between align-items-end mb-4 mb-md-5">
        <div>
          <p class="home-section-label">Recognition</p>
          <h2 class="home-section-title">Grants &amp; Awards</h2>
        </div>
        <div class="awards-slider-nav">
          <button class="awards-slider-btn" data-action="click->awards-slider#prev" aria-label="Previous">
            <i class="fa-solid fa-arrow-left"></i>
          </button>
          <button class="awards-slider-btn" data-action="click->awards-slider#next" aria-label="Next">
            <i class="fa-solid fa-arrow-right"></i>
          </button>
        </div>
      </div>

      <div class="awards-slider-track" data-awards-slider-target="track" data-scroll-reveal-target="fromBottom">
        <% @featured_grants.each do |item| %>
          <div class="awards-slider-card">

            <%# Top — icon + category label %>
            <div class="d-flex align-items-center gap-2">
              <div class="awards-card-icon awards-card-icon--<%= item.category %>">
                <i class="fa-solid <%= item.category == "award" ? "fa-trophy" : "fa-hand-holding-dollar" %>"></i>
              </div>
              <span class="awards-card-category"><%= item.category.capitalize %></span>
            </div>

            <%# Title %>
            <h3 class="awards-card-title"><%= item.title %></h3>

            <%# Description %>
            <% if item.description.present? %>
              <p class="awards-card-desc"><%= item.description %></p>
            <% end %>

            <%# Footer — awarding body + year %>
            <div class="awards-card-footer">
              <div class="awards-card-footer-icon">
                <i class="fa-solid fa-building-columns"></i>
              </div>
              <div>
                <% if item.awarding_body.present? %>
                  <p class="awards-card-footer-name"><%= item.awarding_body %></p>
                <% end %>
                <% if item.year.present? %>
                  <p class="awards-card-footer-year"><%= item.year %></p>
                <% end %>
              </div>
            </div>

          </div>
        <% end %>
      </div>

      <% if user_signed_in? %>
        <div class="mt-4">
          <%= link_to "View all &rarr;".html_safe, grant_awards_path, class: "home-section-viewall" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<%# ===== FEATURED BLOG POSTS ===== %>
<% if @featured_posts.any? %>
  <section class="home-section" id="blog" data-controller="scroll-reveal">
    <div class="container">
      <div class="d-flex justify-content-between align-items-end mb-4 mb-md-5">
        <div>
          <p class="home-section-label">Writing</p>
          <h2 class="home-section-title">Latest Thinking</h2>
        </div>
        <%= link_to "View all posts &rarr;".html_safe, blog_posts_path, class: "home-section-viewall" %>
      </div>

      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% @featured_posts.each do |post| %>
          <div class="col" data-scroll-reveal-target="fromBottom">
            <article class="home-blog-card">
              <%# Image %>
              <%= link_to post do %>
                <% if post.featured_image.attached? %>
                  <%= image_tag post.featured_image, class: "home-blog-card-img", alt: post.title %>
                <% else %>
                  <div class="home-blog-card-placeholder">
                    <i class="fa-solid fa-newspaper"></i>
                  </div>
                <% end %>
              <% end %>

              <%# Body %>
              <div class="home-blog-card-body">
                <p class="home-blog-card-date">
                  <i class="fa-regular fa-calendar me-1"></i>
                  <%= post.created_at.strftime("%b %-d, %Y") %>
                </p>
                <h3 class="home-blog-card-title">
                  <%= link_to post.title, post, class: "home-blog-card-title-link" %>
                </h3>
                <% if post.blog_excerpt.present? %>
                  <p class="home-blog-card-excerpt"><%= post.blog_excerpt %></p>
                <% end %>
                <div class="home-blog-card-footer">
                  <%= link_to "Read more", post, class: "home-blog-read-more" %>
                </div>
              </div>
            </article>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ===== CONTACT ===== %>
<%= render "pages/contact" %>
