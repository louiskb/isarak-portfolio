<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <url>
    <loc><%= root_url %></loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc><%= blog_posts_url %></loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc><%= research_items_url %></loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc><%= teachings_url %></loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <% @blog_posts.each do |post| %>
  <url>
    <loc><%= blog_post_url(post) %></loc>
    <lastmod><%= post.updated_at.utc.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <% end %>

  <% @research_items.each do |item| %>
  <url>
    <loc><%= research_item_url(item) %></loc>
    <lastmod><%= item.updated_at.utc.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <% end %>

  <% @teachings.each do |teaching| %>
  <url>
    <loc><%= teaching_url(teaching) %></loc>
    <lastmod><%= teaching.updated_at.utc.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <% end %>

</urlset>
