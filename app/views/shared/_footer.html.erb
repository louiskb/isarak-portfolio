<footer class="site-footer">
  <div class="container-fluid px-4">
    <div class="row align-items-center gy-2">

      <%# Left: legal links + discrete login %>
      <div class="col-12 col-md-4 footer-legal text-center text-md-start">
        <%= link_to "Privacy Policy", "#" %>
        &ensp;&middot;&ensp;
        <%= link_to "Terms of Service", "#" %>
        <%# Discrete login — only shown on the research page, when not signed in %>
        <% if !user_signed_in? && request.path.start_with?(research_items_path) %>
          &ensp;&middot;&ensp;
          <%= link_to "Login", new_user_session_path %>
        <% end %>
      </div>

      <%# Centre: copyright %>
      <div class="col-12 col-md-4 text-center footer-copyright order-md-2">
        &copy; <%= Date.current.year %> Isara Khanjanasthiti. All rights reserved.
      </div>

      <%# Right: social icons %>
      <div class="col-12 col-md-4 footer-social d-flex align-items-center justify-content-center justify-content-md-end">
        <a href="#" title="LinkedIn" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-linkedin"></i>
        </a>
        <a href="#" title="ResearchGate" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-researchgate"></i>
        </a>
        <a href="#" title="Google Scholar" target="_blank" rel="noopener noreferrer">
          <i class="fas fa-graduation-cap"></i>
        </a>
        <a href="#" title="Twitter / X" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-x-twitter"></i>
        </a>
      </div>

    </div>
  </div>
</footer>
