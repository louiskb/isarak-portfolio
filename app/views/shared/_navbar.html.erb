<nav class="navbar navbar-expand-lg navbar-isarak">
  <div class="container">

    <%# Left: Logo (always visible) %>
    <%= link_to root_path, class: "navbar-brand mb-0" do %>
      <div class="navbar-logo-mark">IK</div>
    <% end %>

    <% if user_signed_in? %>
      <%# ===== SIGNED-IN (ISARA) NAV ===== %>

      <%# Mobile: toggler %>
      <button class="navbar-toggler" type="button"
              data-bs-toggle="collapse" data-bs-target="#navbarNav"
              aria-controls="navbarNav" aria-expanded="false"
              aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">

        <%# Center nav — Portfolio | Research | Teaching | Awards | Blog (dropdown) %>
        <ul class="navbar-nav mx-auto nav-links-pill align-items-center gap-1">
          <li class="nav-item">
            <%= link_to "Portfolio", root_path, class: nav_link_class(root_path), "aria-current": (current_page?(root_path) ? "page" : nil) %>
          </li>
          <li class="nav-item">
            <%= link_to "Research", research_items_path, class: nav_link_class(research_items_path) %>
          </li>
          <li class="nav-item">
            <%= link_to "Teaching", teachings_path, class: nav_link_class(teachings_path) %>
          </li>
          <li class="nav-item">
            <%= link_to "Awards", grant_awards_path, class: nav_link_class(grant_awards_path) %>
          </li>

          <%# Blog dropdown %>
          <li class="nav-item dropdown">
            <a href="#"
               class="<%= nav_link_class(blog_posts_path) %> dropdown-toggle"
               id="blogDropdown"
               role="button"
               data-bs-toggle="dropdown"
               aria-haspopup="true"
               aria-expanded="false">
              Blog
            </a>
            <div class="dropdown-menu" aria-labelledby="blogDropdown">
              <%= link_to "All Posts", blog_posts_path, class: "dropdown-item" %>
              <hr class="dropdown-divider">
              <%= link_to "New Post", new_blog_post_path, class: "dropdown-item" %>
              <%= link_to "✨ Create with AI", ai_new_blog_posts_path, class: "dropdown-item" %>
            </div>
          </li>
        </ul>

        <%# Right nav — Avatar dropdown (desktop) %>
        <ul class="navbar-nav ms-lg-3 align-items-center">
          <li class="nav-item dropdown">
            <a href="#"
               class="nav-link p-0 d-flex align-items-center gap-1"
               id="avatarDropdown"
               role="button"
               data-bs-toggle="dropdown"
               aria-haspopup="true"
               aria-expanded="false">
              <div class="avatar-initials">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, class: "avatar-img", alt: current_user.name || "" %>
                <% else %>
                  <%= (current_user.name.present? ? current_user.name[0] : current_user.email[0]).upcase %>
                <% end %>
              </div>
              <i class="fa-solid fa-chevron-down avatar-chevron"></i>
            </a>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="avatarDropdown">
              <%= link_to "Profile", profile_path, class: "dropdown-item" %>
              <hr class="dropdown-divider">
              <%= button_to "Logout", destroy_user_session_path,
                  method: :delete,
                  class: "dropdown-item text-start border-0 bg-transparent w-100",
                  form: { "data-turbo": "false" } %>
            </div>
          </li>
        </ul>

        <%# Mobile — stacked profile/logout inside collapse %>
        <div class="d-lg-none mt-2 pt-2 border-top border-secondary">
          <%= link_to "Profile", profile_path, class: "nav-link py-2" %>
          <%= button_to "Logout", destroy_user_session_path,
              method: :delete,
              class: "nav-link text-start border-0 bg-transparent w-100 py-2",
              form: { "data-turbo": "false" } %>
        </div>

      </div>

    <% else %>
      <%# ===== VISITOR NAV ===== %>

      <%# Mobile: toggler %>
      <button class="navbar-toggler" type="button"
              data-bs-toggle="collapse" data-bs-target="#navbarNav"
              aria-controls="navbarNav" aria-expanded="false"
              aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav mx-auto nav-links-pill align-items-center gap-1">
          <li class="nav-item">
            <%= link_to "Portfolio", root_path, class: nav_link_class(root_path), "aria-current": (current_page?(root_path) ? "page" : nil) %>
          </li>
          <li class="nav-item">
            <%= link_to "Research", "#research", class: nav_link_class("#research") %>
          </li>
          <li class="nav-item">
            <%= link_to "Blog", blog_posts_path, class: nav_link_class(blog_posts_path) %>
          </li>
        </ul>
      </div>

      <%# Right: Contact Me CTA (always visible) %>
      <%= link_to "Contact Me", "#contact", class: "btn-nav-cta btn-nav-cta-sm d-lg-none" %>
      <%= link_to "Contact Me", "#contact", class: "btn-nav-cta d-none d-lg-block" %>

    <% end %>

  </div>
</nav>
