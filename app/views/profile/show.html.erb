<% content_for :title, "Profile — Isara Khanjanasthiti" %>

<div class="profile-page">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <%# ===== PAGE HEADER ===== %>
        <div class="profile-header">
          <p class="profile-label">Account</p>
          <h1 class="profile-title">Your Profile</h1>
        </div>

        <%= render "shared/flashes" %>

        <%= form_with url: profile_path, method: :patch, multipart: true do |f| %>

          <%# ===== AVATAR ===== %>
          <div class="profile-card">
            <h2 class="profile-card-title">Avatar</h2>
            <div class="d-flex align-items-center gap-4 flex-wrap">
              <div class="avatar-preview-lg">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, alt: current_user.name || "Avatar" %>
                <% else %>
                  <%= (current_user.name.present? ? current_user.name[0] : current_user.email[0]).upcase %>
                <% end %>
              </div>
              <div class="flex-grow-1">
                <label class="profile-input-label">Upload new avatar</label>
                <%= f.file_field :avatar, class: "form-control form-control-dark", accept: "image/*" %>
                <p class="profile-input-hint">Shown in the navbar. JPG or PNG, square crop recommended.</p>
              </div>
            </div>
          </div>

          <%# ===== NAME ===== %>
          <div class="profile-card">
            <h2 class="profile-card-title">Display Name</h2>
            <label class="profile-input-label" for="user_name">Name</label>
            <%= f.text_field :name,
                  id: "user_name",
                  class: "form-control form-control-dark",
                  value: current_user.name,
                  placeholder: "Dr Isara Khanjanasthiti" %>
          </div>

          <%# ===== ABOUT ME ===== %>
          <div class="profile-card">
            <h2 class="profile-card-title">About Me</h2>
            <p class="profile-input-hint mb-3">
              This bio appears in the <strong>About</strong> section of your public landing page, directly below
              your name and title. Write 2–4 sentences — keep it personal, professional, and in first person.
            </p>
            <label class="profile-input-label" for="user_about">Bio</label>
            <%= f.text_area :about,
                  id: "user_about",
                  class: "form-control form-control-dark",
                  rows: 5,
                  value: current_user.about,
                  placeholder: "I am an urban and regional planning academic at the University of New England (UNE)..." %>
          </div>

          <%# ===== CV ===== %>
          <div class="profile-card">
            <h2 class="profile-card-title">Curriculum Vitae</h2>
            <% if current_user.cv.attached? %>
              <div class="profile-cv-existing d-flex align-items-center gap-3 mb-3">
                <i class="fa-regular fa-file-pdf profile-cv-icon"></i>
                <div>
                  <p class="mb-0 profile-cv-filename"><%= current_user.cv.filename %></p>
                  <p class="mb-0 profile-input-hint">
                    <%= number_to_human_size(current_user.cv.byte_size) %> &middot;
                    Uploaded <%= current_user.cv.created_at.strftime("%b %-d, %Y") %>
                  </p>
                </div>
              </div>
            <% end %>
            <label class="profile-input-label"><%= current_user.cv.attached? ? "Replace CV" : "Upload CV" %></label>
            <%= f.file_field :cv, class: "form-control form-control-dark", accept: ".pdf" %>
            <p class="profile-input-hint">PDF only. This will be available as a download link on your public portfolio.</p>
          </div>

          <%# ===== SAVE BUTTON ===== %>
          <div class="d-flex gap-3 align-items-center">
            <%= f.submit "Save changes", class: "btn btn-profile-save" %>
          </div>

        <% end %>

        <%# ===== ACCOUNT SECURITY ===== %>
        <div class="profile-card mt-4">
          <h2 class="profile-card-title">Email & Password</h2>
          <p class="profile-input-hint mb-3">Change your login email or password via the Devise account settings page.</p>
          <%= link_to "Change email or password →", edit_user_registration_path, class: "btn btn-profile-secondary" %>
        </div>

      </div>
    </div>
  </div>
</div>
