<% content_for :title, "#{@research_item.title} — Research" %>

<div class="resource-detail">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <nav aria-label="breadcrumb" class="mb-4">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Research", research_items_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @research_item.title %></li>
          </ol>
        </nav>

        <%= render "shared/flashes" %>

        <article>
          <div class="resource-detail-header">
            <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
              <span class="resource-card-category resource-badge-<%= @research_item.category %>">
                <%= ResearchItem::CATEGORY_LABELS[@research_item.category] %>
              </span>
            </div>

            <h1 class="resource-detail-title"><%= @research_item.title %></h1>

            <div class="resource-detail-meta">
              <% if @research_item.published_at.present? %>
                <span>
                  <i class="fa-regular fa-calendar me-1"></i>
                  <%= @research_item.published_at.strftime("%B %Y") %>
                </span>
              <% end %>
              <% if @research_item.featured? %>
                <span class="resource-featured-badge">
                  <i class="fa-solid fa-star me-1"></i>Featured
                </span>
              <% end %>
              <% if @research_item.external_url.present? %>
                <span>
                  <i class="fa-solid fa-link me-1"></i>
                  <%= link_to "View paper", @research_item.external_url, target: "_blank", rel: "noopener noreferrer" %>
                </span>
              <% end %>
            </div>
          </div>

          <% if @research_item.description.present? %>
            <div class="resource-detail-description">
              <%= simple_format @research_item.description %>
            </div>
          <% end %>

          <% if @research_item.image.attached? || @research_item.image_url.present? %>
            <div class="mt-4">
              <% if @research_item.image.attached? %>
                <%= image_tag @research_item.image, alt: @research_item.title,
                      class: "img-fluid rounded",
                      style: "max-height: 420px; object-fit: cover; width: 100%;" %>
              <% else %>
                <%= image_tag @research_item.image_url, alt: @research_item.title,
                      class: "img-fluid rounded",
                      style: "max-height: 420px; object-fit: cover; width: 100%;" %>
              <% end %>
            </div>
          <% end %>
        </article>

        <%# Admin actions %>
        <div class="resource-detail-actions">
          <%= link_to "Edit", edit_research_item_path(@research_item), class: "btn btn-resource-edit rounded-4" %>
          <%= button_to "Delete", @research_item,
                method: :delete,
                class: "btn btn-resource-delete rounded-4",
                data: { turbo_confirm: "Delete \"#{@research_item.title}\"? This cannot be undone." } %>
        </div>

      </div>
    </div>
  </div>
</div>
