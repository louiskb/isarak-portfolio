<% content_for :title, "Research — Isara Khanjanasthiti" %>

<%# ===== HERO ===== %>
<section class="resource-hero">
  <div class="container">
    <div class="resource-hero-inner">
      <p class="resource-hero-label">Research</p>
      <h1 class="resource-hero-title">Research & Publications</h1>
      <p class="resource-hero-subtitle">
        Urban planning, aviation policy, housing governance, and university teaching & learning.
      </p>
      <% if user_signed_in? %>
        <p class="resource-hero-subtitle resource-hero-info mt-2">
          <i class="fa-solid fa-star me-1" style="color: #facc15;"></i>Tick <strong>`Featured`</strong> on an item to include it in the homepage Research section — <span class="hi-teal">max 4 shown, most recently updated first</span>. If you feature more than 4, the most recently edited items take priority. <span class="hi-grad">Drag reorders this page only</span> — it does not affect the homepage.
        </p>
      <% end %>
      <% if user_signed_in? %>
        <div class="mt-4">
          <%= link_to "Add Research Item", new_research_item_path, class: "btn btn-grad" %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== GRID ===== %>
<section class="resource-grid-section">
  <div class="container">
    <% if @research_items.any? %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4"
           <% if user_signed_in? %>data-controller="sortable" data-sortable-url-value="<%= reorder_research_items_path %>"<% end %>>
        <% @research_items.each do |item| %>
          <div class="col" data-id="<%= item.id %>">
            <article class="resource-card card">
              <% if user_signed_in? %>
                <div class="drag-handle" title="Drag to reorder">
                  <i class="fa-solid fa-grip-vertical"></i>
                </div>
              <% end %>
              <% img_src = item.image.attached? ? (url_for(item.image) rescue nil) : item.image_url.presence %>
              <% if img_src %>
                <img src="<%= img_src %>" class="resource-card-img" alt="<%= item.title %>">
              <% end %>
              <div class="card-body">
                <%# Category badge + status badge (Isara only) %>
                <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                  <span class="resource-card-category resource-badge-<%= item.category %>">
                    <%= ResearchItem::CATEGORY_LABELS[item.category] %>
                  </span>
                  <% if user_signed_in? %>
                    <span class="badge rounded-pill blog-status-<%= item.status %>">
                      <%= item.status.capitalize %>
                    </span>
                  <% end %>
                </div>

                <h2 class="resource-card-title">
                  <%= link_to item.title, research_item_path(item), class: "resource-card-title-link" %>
                </h2>

                <% if item.published_at.present? || (user_signed_in? && item.scheduled? && item.scheduled_at) %>
                  <p class="resource-card-meta">
                    <% if item.published_at.present? %>
                      <i class="fa-regular fa-calendar me-1"></i>
                      <%= item.published_at.strftime("%B %Y") %>
                    <% end %>
                    <% if item.featured? %>&nbsp;<i class="fa-solid fa-star ms-1" title="Featured"></i><% end %>
                    <% if user_signed_in? && item.scheduled? && item.scheduled_at %>
                      &nbsp;· Scheduled <%= item.scheduled_at.strftime("%-d %b %Y at %H:%M") %>
                    <% end %>
                  </p>
                <% end %>

                <% if item.description.present? %>
                  <p class="resource-card-description"><%= item.description %></p>
                <% end %>

                <div class="resource-card-footer">
                  <%= link_to "View →", research_item_path(item), class: "btn btn-resource-link btn-sm" %>
                  <% if user_signed_in? %>
                    <%= link_to "Manage →", research_item_path(item), class: "btn btn-resource-manage btn-sm ms-auto" %>
                  <% end %>
                </div>
              </div>
            </article>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="resource-empty text-center">
        <p class="text-muted mb-3">No research items yet.</p>
        <% if user_signed_in? %>
          <%= link_to "Add your first item", new_research_item_path, class: "btn btn-resource-add" %>
        <% end %>
      </div>
    <% end %>

    <div class="mt-5">
      <%= raw @pagy.series_nav(:bootstrap) if @pagy.pages > 1 %>
    </div>
  </div>
</section>
