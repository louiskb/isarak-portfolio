
<%= simple_form_for(@research_item, html: { multipart: true, data: { controller: "load-button" } }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%= f.input :title,
          hint: "The full title of the paper, project, or publication." %>

    <%= f.input :category,
          collection: ResearchItem::CATEGORY_LABELS.map { |k, v| [v, k] },
          include_blank: "Select a category",
          hint: "Select the type that best describes this research item." %>

    <%= f.input :description,
          as: :text,
          input_html: { rows: 4 },
          hint: "A short summary shown on the index card (2–4 sentences)." %>

    <%= f.input :external_url,
          label: "External URL",
          hint: "Link to the journal, conference proceedings, or hosted project page." %>

    <%= f.input :published_at,
          as: :date,
          label: "Published / presented date",
          hint: "Used to sort and display the month & year on the card." %>

    <%= f.input :image,
          as: :file,
          label: "Research image (optional)",
          hint: "Upload a JPG or PNG. Shown as a full-bleed card image on the homepage.",
          input_html: { accept: "image/*", class: "form-control form-control-dark" } %>
    <% if f.object.persisted? && f.object.image.attached? %>
      <% attached_url = url_for(f.object.image) rescue nil %>
      <% if attached_url %>
        <div class="mb-3">
          <p class="profile-input-hint mb-1">Current uploaded image:</p>
          <%= link_to attached_url, target: "_blank", rel: "noopener noreferrer" do %>
            <%= image_tag attached_url, class: "img-fluid rounded", style: "max-height: 160px; object-fit: cover;" %>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%= f.input :image_url,
          label: "Research image URL (optional)",
          placeholder: "https://example.com/image.jpg",
          hint: "Fallback if no image is uploaded above." %>
    <% if f.object.persisted? && f.object.image_url.present? %>
      <div class="mb-3">
        <p class="profile-input-hint mb-1">Current image URL:</p>
        <%= link_to f.object.image_url, target: "_blank", rel: "noopener noreferrer" do %>
          <%= image_tag f.object.image_url, class: "img-fluid rounded", style: "max-height: 160px; object-fit: cover;" %>
        <% end %>
      </div>
    <% end %>

    <%= f.input :featured,
          label: "Featured item",
          hint: "Shows in the homepage Research section (top 4 by drag order on the index page)." %>

    <%= f.input :slug,
          hint: "Auto-generated from the title. Edit only if you need a custom URL." %>
  </div>

  <div class="form-actions" data-load-button-target="buttons">
    <%= f.button :submit, class: "btn btn-resource-add rounded-4",
          data: { action: "click->load-button#showSpinner",
                  load_button_loading_text_value: "Saving..." } %>
  </div>
<% end %>
