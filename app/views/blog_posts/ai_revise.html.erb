<% content_for :title, "Revise with AI — #{@blog_post.title}" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Blog", blog_posts_path %></li>
          <li class="breadcrumb-item"><%= link_to @blog_post.title, @blog_post %></li>
          <li class="breadcrumb-item active" aria-current="page">Revise with AI</li>
        </ol>
      </nav>

      <div class="mb-5">
        <h1 class="mb-2"><i class="fa-solid fa-wand-magic-sparkles text-primary me-2"></i>Revise with AI</h1>
        <p class="text-muted mb-0"><%= @blog_post.title %></p>
      </div>

      <% if flash[:alert] %>
        <div class="alert alert-danger mb-4"><%= flash[:alert] %></div>
      <% end %>

      <%# Current content — collapsed by default, expandable %>
      <div class="mb-5">
        <a class="d-flex align-items-center justify-content-between text-decoration-none px-3 py-2 rounded border content-toggle"
           data-bs-toggle="collapse" href="#currentContentPreview" role="button"
           aria-expanded="false" aria-controls="currentContentPreview">
          <span class="d-flex align-items-center gap-2">
            <span class="small fw-semibold text-uppercase" style="letter-spacing: 0.06em;">Current content</span>
            <% if @blog_post.ai_generated? %>
              <span class="badge bg-primary text-dark" style="font-size: 0.7rem;">AI Generated</span>
            <% end %>
          </span>
          <i class="fa-solid fa-chevron-down small text-muted"></i>
        </a>
        <div class="collapse" id="currentContentPreview">
          <div class="border rounded p-3" style="max-height: 300px; overflow-y: auto; font-size: 0.875rem;">
            <% if @blog_post.blog_post_erb_content.present? %>
              <%= raw @blog_post.blog_post_erb_content %>
            <% elsif @blog_post.body.present? %>
              <%= @blog_post.body %>
            <% else %>
              <p class="text-muted fst-italic mb-0">No content yet.</p>
            <% end %>
          </div>
        </div>
      </div>

      <hr class="mb-5">

      <%= simple_form_for :blog_post, url: revise_with_ai_blog_post_path(@blog_post), method: :patch,
            html: { multipart: true, data: {
              controller: "publish-form load-button",
              "publish-form-current-status-value": @blog_post.status
            } } do |f| %>

        <div class="mb-5">
          <%= f.label :featured_image, "Featured image", class: "form-label" %>
          <% if @blog_post.featured_image.attached? %>
            <div class="mb-3">
              <p class="profile-input-hint mb-1">Current image:</p>
              <%= image_tag @blog_post.featured_image,
                    class: "img-fluid rounded",
                    style: "max-height:160px;object-fit:cover;" %>
            </div>
            <div class="form-check mb-3">
              <%= f.check_box :keep_featured_image, class: "form-check-input" %>
              <%= f.label :keep_featured_image, "Keep this image", class: "form-check-label" %>
            </div>
            <div class="form-text mb-3">By default the AI fetches a fresh Unsplash photo. Check the box above to keep your current image instead.</div>
            <%= f.file_field :featured_image, class: "form-control", accept: "image/*" %>
            <div class="form-text">Or upload a different image.</div>
          <% else %>
            <%= f.file_field :featured_image, class: "form-control", accept: "image/*" %>
            <div class="form-text">Leave blank and the AI will find a relevant photo automatically.</div>
          <% end %>
        </div>

        <div class="mb-5">
          <%= f.label :image_url, "Fallback image URL", class: "form-label" %>
          <%= f.text_field :image_url, class: "form-control", value: @blog_post.image_url, placeholder: "https://picsum.photos/seed/example/800/600" %>
          <div class="form-text">Used when no uploaded image is attached. Paste any public image URL.</div>
        </div>

        <div class="mb-5">
          <%= f.label :prompt, "How should the AI revise this post?", class: "form-label" %>
          <%= f.text_area :prompt,
                value: @prompt,
                rows: 5,
                class: "form-control",
                placeholder: "e.g. \"Add a section on policy implications\" or \"Shorten to 400 words and make it punchier\"" %>
          <div class="form-text">Describe the changes you'd like — the AI will preserve the rest.</div>
        </div>

        <%# Hidden fields — controlled by the split button via the publish-form Stimulus controller %>
        <input type="hidden"
               name="blog_post[status]"
               value="<%= @blog_post.status %>"
               data-publish-form-target="statusInput">
        <input type="hidden"
               name="blog_post[scheduled_at]"
               value="<%= @blog_post.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
               data-publish-form-target="scheduledAtInput">

        <%# ===== SPLIT PUBLISH BUTTON ===== %>
        <% if @blog_post.scheduled? %>
          <p class="small text-warning mb-3">
            <i class="fa-regular fa-clock me-1"></i>
            Scheduled to publish on <%= @blog_post.scheduled_at.strftime("%d %b %Y at %H:%M") %>
            &mdash; use the dropdown to reschedule or change status.
          </p>
        <% elsif @blog_post.published? %>
          <p class="small text-success mb-3">
            <i class="fa-solid fa-circle-check me-1"></i>
            This post is published and visible to everyone
            &mdash; use the dropdown to change status.
          </p>
        <% else %>
          <p class="small text-muted mb-3">
            <i class="fa-regular fa-file-lines me-1"></i>
            This post is a draft and not visible to the public
            &mdash; use the dropdown to change status.
          </p>
        <% end %>

        <div class="d-flex align-items-center gap-3 flex-wrap" data-load-button-target="buttons">
          <div class="btn-group dropup">

            <%# Default: revise and keep current status %>
            <button type="button" class="btn btn-blog-publish btn-publish-main"
                    data-action="click->load-button#loader click->publish-form#saveChanges"
                    data-load-button-loading-text-value="Revising your post...">
              Revise post
            </button>

            <%# Chevron — opens upward dropdown %>
            <button type="button"
                    class="btn btn-blog-publish btn-publish-chevron dropdown-toggle dropdown-toggle-split"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
              <span class="visually-hidden">More publishing options</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <button type="button" class="dropdown-item"
                        data-action="click->load-button#loader click->publish-form#saveDraft"
                        data-load-button-loading-text-value="Revising your post...">
                  <i class="fa-regular fa-file me-2 text-muted"></i>Revise and save as draft
                </button>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <button type="button" class="dropdown-item"
                        data-action="click->load-button#loader click->publish-form#publishNow"
                        data-load-button-loading-text-value="Revising and publishing...">
                  <i class="fa-solid fa-globe me-2 text-muted"></i>Revise and publish now
                </button>
              </li>
              <li>
                <button type="button" class="dropdown-item"
                        data-bs-toggle="modal" data-bs-target="#schedulePostModal">
                  <i class="fa-regular fa-clock me-2 text-muted"></i>Revise and schedule&hellip;
                </button>
              </li>
            </ul>
          </div>

          <%= link_to "Cancel", @blog_post, class: "btn btn-resource-edit" %>
        </div>

        <%# ===== SCHEDULE MODAL ===== %>
        <div class="modal fade" id="schedulePostModal" tabindex="-1"
             aria-labelledby="schedulePostModalLabel" aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="schedulePostModalLabel">
                  <i class="fa-regular fa-clock me-2"></i>Schedule post
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <p class="text-muted mb-3">
                  The AI will revise the post, then schedule it to go live at the time you choose.
                </p>
                <label class="form-label fw-semibold" for="schedule-post-datetime">Publish at</label>
                <input type="datetime-local"
                       id="schedule-post-datetime"
                       class="form-control"
                       min="<%= Time.current.strftime("%Y-%m-%dT%H:%M") %>"
                       value="<%= @blog_post.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
                       data-publish-form-target="scheduleInput"
                       required>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-blog-publish"
                        data-action="click->load-button#loader click->publish-form#confirmSchedule"
                        data-load-button-loading-text-value="Revising your post...">
                  Revise and schedule
                </button>
              </div>
            </div>
          </div>
        </div>

      <% end %>

    </div>
  </div>
</div>
