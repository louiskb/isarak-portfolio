<% content_for :title, "Blog — Isara Khanjanasthiti" %>

<%# ===== BLOG HERO ===== %>
<section class="blog-hero">
  <div class="container">
    <div class="blog-hero-inner">
      <p class="blog-hero-label">Writing</p>
      <h1 class="blog-hero-title">Thoughts on planning,<br>research & academia</h1>
      <p class="blog-hero-subtitle">
        Ideas and reflections from urban planning, housing policy, and university teaching.
      </p>
      <% if user_signed_in? %>
        <p class="blog-hero-subtitle resource-hero-info mt-2">
          <i class="fa-solid fa-star me-1" style="color: #facc15;"></i>Tick <strong>`Featured`</strong> on a post to include it in the homepage Blog section — <span class="hi-teal">max 3 shown, most recently updated first</span>. If you feature more than 3, the most recently edited posts take priority. <span class="hi-grad">Blog posts are ordered newest first</span> — no drag reordering.
        </p>
        <div class="d-flex gap-2 mt-4">
          <%= link_to "New post", new_blog_post_path, class: "btn btn-grad" %>
          <%= link_to ai_new_blog_posts_path, class: "btn home-btn-outline" do %>
              <i class="fa-solid fa-wand-magic-sparkles"></i> Create with AI
            <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== SEARCH + FILTER BAR ===== %>
<section class="blog-filter-section">
  <div class="container">
    <%= form_with url: blog_posts_path, method: :get,
          data: { controller: "blog-filter", turbo_action: "replace" },
          local: true do |f| %>

      <div class="blog-search-wrapper">
        <%= f.search_field :q,
              value: params[:q],
              placeholder: "Search posts…",
              class: "blog-search-input",
              autocomplete: "off",
              data: { action: "input->blog-filter#search" } %>
        <i class="fa-solid fa-magnifying-glass blog-search-icon"></i>
      </div>

      <% if @all_tags.any? %>
        <div class="blog-tag-filter mt-3">
          <% active_tag_ids = Array(params[:tag_ids]).map(&:to_s) %>
          <% @all_tags.each do |tag| %>
            <label class="blog-tag-pill <%= "active" if active_tag_ids.include?(tag.id.to_s) %>">
              <%= check_box_tag "tag_ids[]", tag.id,
                    active_tag_ids.include?(tag.id.to_s),
                    class: "visually-hidden",
                    data: { action: "change->blog-filter#submit" } %>
              <%= tag.name %>
            </label>
          <% end %>
        </div>
      <% end %>

    <% end %>
  </div>
</section>

<%# ===== BLOG GRID ===== %>
<section class="blog-grid-section">
  <div class="container">
    <% if @blog_posts.any? %>
      <div class="row row-cols-1 row-cols-lg-3 g-4">
        <% @blog_posts.each do |post| %>
          <div class="col">
            <article class="card blog-card h-100">

              <%# Image — clickable link to show page %>
              <%= link_to post, class: "blog-card-img-link" do %>
                <div class="position-relative overflow-hidden blog-card-img-top">
                  <div class="ratio ratio-16x9">
                    <% if post.featured_image.attached? %>
                      <%= image_tag post.featured_image,
                            alt: post.title,
                            class: "object-fit-cover blog-card-image" %>
                    <% elsif post.image_url.present? %>
                      <img src="<%= post.image_url %>" alt="<%= post.title %>" class="object-fit-cover blog-card-image">
                    <% else %>
                      <div class="blog-card-placeholder d-flex align-items-center justify-content-center">
                        <i class="fa-solid fa-newspaper blog-card-placeholder-icon"></i>
                      </div>
                    <% end %>
                  </div>

                </div>
              <% end %>

              <%# Card body %>
              <div class="card-body d-flex flex-column">
                <%# Status + AI label row — Isara only %>
                <% if user_signed_in? %>
                  <div class="d-flex align-items-center gap-3 mb-2">
                    <span class="badge rounded-pill blog-status-<%= post.status %>">
                      <%= post.status.capitalize %>
                    </span>
                    <% if post.ai_label %>
                      <span class="blog-card-ai-label">
                        <i class="fa-solid fa-wand-magic-sparkles me-1"></i><%= post.ai_label %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
                <div class="blog-card-meta">
                  <i class="fa-regular fa-calendar me-1"></i>
                  <%= post.created_at.strftime("%b %-d, %Y") %>
                  <% if user_signed_in? && post.scheduled? && post.scheduled_at %>
                    &nbsp;· Scheduled <%= post.scheduled_at.strftime("%-d %b %Y at %H:%M") %>
                  <% end %>
                  <% if post.featured? %>
                    &nbsp;<i class="fa-solid fa-star ms-1" title="Featured"></i>
                  <% end %>
                </div>

                <h2 class="blog-card-title">
                  <%= link_to post.title, post, class: "blog-card-title-link" %>
                </h2>

                <% if post.blog_excerpt.present? %>
                  <p class="blog-card-excerpt"><%= post.blog_excerpt %></p>
                <% end %>

                <%# Footer row: Read more + Manage button (Isara only) %>
                <div class="blog-card-footer mt-auto">
                  <%= link_to "Read more", post, class: "blog-card-read-more" %>
                  <% if user_signed_in? %>
                    <%= link_to "Manage →", post, class: "btn btn-resource-manage btn-sm ms-auto" %>
                  <% end %>
                </div>
              </div>

            </article>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="blog-empty text-center py-5">
        <% if params[:q].present? || params[:tag_ids].present? %>
          <p class="text-muted mb-3">No posts match your search or filter.</p>
          <%= link_to "Clear filters", blog_posts_path, class: "btn home-btn-outline btn-sm" %>
        <% else %>
          <p class="text-muted mb-3">No posts published yet.</p>
          <% if user_signed_in? %>
            <%= link_to "Write your first post", new_blog_post_path, class: "btn btn-primary" %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <div class="mt-5">
      <%= raw @pagy.series_nav(:bootstrap) if @pagy.pages > 1 %>
    </div>
  </div>
</section>
