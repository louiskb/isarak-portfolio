<%= simple_form_for(@blog_post,
      html: { multipart: true, data: {
        controller: "publish-form load-button",
        "publish-form-current-status-value": (@blog_post.status || "draft")
      } }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%= f.input :title %>
    <%= f.input :blog_excerpt,
          label: "Excerpt",
          hint: "A 1–2 sentence preview shown on the Blog page.",
          as: :text,
          input_html: { rows: 3 } %>
    <%= f.input :featured,
          label: "Featured post",
          hint: "Featured posts appear on your Portfolio homepage (top 3–6 shown). Posts are always ordered most recent first on the Blog page." %>

    <div class="mb-3">
      <%= f.label :featured_image, "Featured image", class: "form-label" %>
      <% if @blog_post.featured_image.attached? %>
        <div class="mb-2">
          <p class="profile-input-hint mb-1">Current image:</p>
          <%= image_tag @blog_post.featured_image, class: "img-fluid rounded", style: "max-height:160px;object-fit:cover;" %>
        </div>
      <% end %>
      <%= f.input :featured_image, label: false, as: :file, input_html: { accept: "image/*" } %>
      <small class="text-muted">Leave blank to keep the existing image.</small>
    </div>

    <div data-controller="image-preview">
      <%= f.input :image_url,
            label: "Fallback image URL",
            placeholder: "https://picsum.photos/seed/example/800/600",
            hint: "Shown only when no uploaded image is attached. Paste any public image URL.",
            input_html: {
              "data-image-preview-target": "urlInput",
              "data-action": "input->image-preview#updateUrl"
            } %>
      <img class="img-fluid rounded mt-2 d-none"
           style="max-height:160px;object-fit:cover;"
           data-image-preview-target="preview"
           alt="URL preview">
    </div>

    <% if @blog_post.blog_post_erb_content.present? %>
      <%# AI mode: post is managed via raw HTML/ERB content — Trix editor is hidden %>
      <div class="mb-3">
        <%= f.label :blog_post_erb_content, "Content (HTML)", class: "form-label" %>
        <small class="text-muted d-block mb-1">
          This post is managed as HTML. Edit directly or use <strong>✨ Revise with AI</strong> to generate a new version.
        </small>
        <%= f.input :blog_post_erb_content,
              label: false,
              as: :text,
              input_html: { rows: 25, class: "font-monospace" } %>
      </div>
    <% else %>
      <%# Manual mode: Trix rich text editor %>
      <div class="mb-3">
        <%= f.label :body, "Content", class: "form-label" %>
        <%= f.rich_text_area :body %>
      </div>
    <% end %>
  </div>

  <%# Hidden fields — controlled by the split button via the publish-form Stimulus controller %>
  <input type="hidden"
         name="blog_post[status]"
         value="<%= @blog_post.status || "draft" %>"
         data-publish-form-target="statusInput">
  <input type="hidden"
         name="blog_post[scheduled_at]"
         value="<%= @blog_post.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
         data-publish-form-target="scheduledAtInput">

  <%# ===== SPLIT PUBLISH BUTTON ===== %>
  <div class="form-actions d-flex align-items-center gap-3 flex-wrap mt-4" data-load-button-target="buttons">
    <% if @blog_post.persisted? %>
      <% if @blog_post.scheduled? %>
        <p class="small text-warning w-100 mb-1">
          <i class="fa-regular fa-clock me-1"></i>
          Scheduled to publish on <%= @blog_post.scheduled_at.strftime("%d %b %Y at %H:%M") %>
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% elsif @blog_post.published? %>
        <p class="small text-success w-100 mb-1">
          <i class="fa-solid fa-circle-check me-1"></i>
          This post is published and visible to everyone
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% else %>
        <p class="small text-muted w-100 mb-1">
          <i class="fa-regular fa-file-lines"></i>
          This post is a draft and not visible to the public
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% end %>
    <% end %>
    <div class="btn-group dropup">

      <%# Default action button — context-aware label %>
      <% if @blog_post.new_record? %>
        <button type="button" class="btn btn-blog-publish btn-publish-main"
                data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                data-load-button-loading-text-value="Saving...">
          Save as draft
        </button>
      <% else %>
        <button type="button" class="btn btn-blog-publish btn-publish-main"
                data-action="click->load-button#showSpinner click->publish-form#saveChanges"
                data-load-button-loading-text-value="Saving changes...">
          Save changes
        </button>
      <% end %>

      <%# Chevron — opens the upward dropdown %>
      <button type="button"
              class="btn btn-blog-publish btn-publish-chevron dropdown-toggle dropdown-toggle-split"
              data-bs-toggle="dropdown"
              aria-expanded="false">
        <span class="visually-hidden">More publishing options</span>
      </button>

      <ul class="dropdown-menu dropdown-menu-end">
        <% unless @blog_post.new_record? %>
          <li>
            <button type="button" class="dropdown-item"
                    data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                    data-load-button-loading-text-value="Saving...">
              <i class="fa-regular fa-file me-2 text-muted"></i>Save as draft
            </button>
          </li>
          <li><hr class="dropdown-divider"></li>
        <% end %>
        <li>
          <button type="button" class="dropdown-item"
                  data-action="click->load-button#showSpinner click->publish-form#publishNow"
                  data-load-button-loading-text-value="Publishing...">
            <i class="fa-solid fa-globe me-2 text-muted"></i>Publish now
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item"
                  data-bs-toggle="modal" data-bs-target="#schedulePostModal">
            <i class="fa-regular fa-clock me-2 text-muted"></i>Schedule&hellip;
          </button>
        </li>
      </ul>
    </div>
  </div>

  <%# ===== SCHEDULE MODAL ===== %>
  <div class="modal fade" id="schedulePostModal" tabindex="-1"
       aria-labelledby="schedulePostModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="schedulePostModalLabel">
            <i class="fa-regular fa-clock me-2"></i>Schedule post
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted mb-3">Choose when this post will go live automatically.</p>
          <label class="form-label fw-semibold" for="schedule-post-datetime">Publish at</label>
          <input type="datetime-local"
                 id="schedule-post-datetime"
                 class="form-control"
                 min="<%= Time.current.strftime("%Y-%m-%dT%H:%M") %>"
                 value="<%= @blog_post.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
                 data-publish-form-target="scheduleInput"
                 required>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-blog-publish"
                  data-action="click->publish-form#confirmSchedule">
            Schedule post
          </button>
        </div>
      </div>
    </div>
  </div>

<% end %>
