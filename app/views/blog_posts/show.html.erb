<% content_for :title, "#{@blog_post.title} — Blog" %>

<% content_for :meta_tags do %>
  <%
    og_description = @blog_post.blog_excerpt.presence ||
                     truncate(strip_tags(@blog_post.body.present? ? @blog_post.body.to_plain_text : @blog_post.blog_post_erb_content.to_s), length: 160, omission: "…")
    og_image = if @blog_post.featured_image.attached?
                 url_for(@blog_post.featured_image)
               elsif @blog_post.image_url.present?
                 @blog_post.image_url
               else
                 image_url("ik-logo-tp.png")
               end
  %>
  <meta property="og:site_name" content="Dr Isara Khanjanasthiti">
  <meta property="og:title" content="<%= @blog_post.title %>">
  <meta property="og:description" content="<%= og_description %>">
  <meta property="og:url" content="<%= blog_post_url(@blog_post) %>">
  <meta property="og:type" content="article">
  <meta property="og:image" content="<%= og_image %>">
  <meta property="article:author" content="Isara Khanjanasthiti">
  <% if @blog_post.created_at.present? %>
    <meta property="article:published_time" content="<%= @blog_post.created_at.iso8601 %>">
  <% end %>
  <meta name="twitter:card" content="<%= @blog_post.featured_image.attached? || @blog_post.image_url.present? ? "summary_large_image" : "summary" %>">
  <meta name="twitter:title" content="<%= @blog_post.title %>">
  <meta name="twitter:description" content="<%= og_description %>">
  <meta name="twitter:image" content="<%= og_image %>">
<% end %>

<%# Reading progress bar — fixed at top of viewport, only on this page %>
<div class="reading-progress-wrap" data-controller="reading-progress">
  <div class="reading-progress-bar" data-reading-progress-target="bar"></div>
</div>

<div class="blog-show">
  <div class="container">
    <div class="row gx-5 justify-content-center" data-controller="toc">
      <div class="col-lg-8">

        <nav aria-label="breadcrumb" class="mb-4">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Blog", blog_posts_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @blog_post.title %></li>
          </ol>
        </nav>

        <article>
          <%# Title + status badge %>
          <h1 class="blog-show-title mb-2"><%= @blog_post.title %></h1>
          <% if user_signed_in? %>
            <span class="badge rounded-pill blog-status-<%= @blog_post.status %> mb-3">
              <%= @blog_post.status.capitalize %>
            </span>
          <% end %>

          <%# Scheduled indicator (admin only) %>
          <% if @blog_post.scheduled? && user_signed_in? %>
            <div class="d-flex align-items-center gap-2 mb-3">
              <small class="blog-show-meta">
                <i class="fa-regular fa-clock me-1"></i>
                Scheduled for <%= @blog_post.scheduled_at.strftime("%d %b %Y at %H:%M") %> (<%= Time.current.zone %>)
              </small>
              <button type="button"
                      class="btn btn-resource-edit btn-sm"
                      data-bs-toggle="modal"
                      data-bs-target="#editScheduleModal">
                Edit schedule
              </button>
            </div>
          <% end %>

          <p class="blog-show-author">By <%= @blog_post.author %></p>

          <%# Meta %>
          <div class="d-flex align-items-center justify-content-start gap-3 mb-4">
            <p class="blog-show-meta mb-0">
              <i class="fa-regular fa-calendar me-1"></i>
              <%= @blog_post.created_at.strftime("%B %-d, %Y") %>
            </p>
            <p class="blog-show-meta mb-0">
              <i class="fa-regular fa-clock me-1"></i>
              <%= @blog_post.reading_time %>
            </p>
            <% if @blog_post.featured? %>
              <span class="resource-featured-badge">
                <i class="fa-solid fa-star me-1"></i>Featured
              </span>
            <% end %>
            <% if user_signed_in? && @blog_post.ai_label %>
              <span class="blog-card-ai-label">
                <i class="fa-solid fa-wand-magic-sparkles me-1"></i><%= @blog_post.ai_label %>
              </span>
            <% end %>
            <button class="blog-copy-link ms-auto"
                    data-controller="copy-link"
                    data-action="click->copy-link#copy"
                    title="Copy link">
              <i data-copy-link-target="icon" class="fa-solid fa-link"></i>
            </button>
          </div>

          <%# Featured image — uploaded takes priority, then image_url fallback %>
          <% if @blog_post.featured_image.attached? %>
            <figure class="blog-show-image mb-4">
              <%= image_tag @blog_post.featured_image,
                    class: "img-fluid rounded",
                    style: "width:100%;max-height:420px;object-fit:cover;",
                    alt: @blog_post.title %>
              <% if @blog_post.featured_image_caption.present? %>
                <%= raw @blog_post.featured_image_caption %>
              <% end %>
            </figure>
          <% elsif @blog_post.image_url.present? %>
            <figure class="blog-show-image mb-4">
              <img src="<%= @blog_post.image_url %>"
                   class="img-fluid rounded"
                   style="width:100%;max-height:420px;object-fit:cover;"
                   alt="<%= @blog_post.title %>">
              <% if @blog_post.featured_image_caption.present? %>
                <%= raw @blog_post.featured_image_caption %>
              <% end %>
            </figure>
          <% end %>

          <%# Mobile TOC — inline, only shown below lg where the sidebar is hidden %>
          <nav class="blog-toc-mobile d-lg-none mb-4" data-toc-target="mobileNav" hidden>
            <p class="blog-toc-label">In this post</p>
            <ul class="blog-toc-list" data-toc-target="list"></ul>
          </nav>

          <%# Content — TOC controller on the row scans headings here %>
          <div class="blog-post-content" data-toc-target="content">
            <% if @blog_post.blog_post_erb_content.present? %>
              <div data-controller="html-inject" hidden>
                <%= sanitize @blog_post.blog_post_erb_content %>
              </div>
            <% elsif @blog_post.body.present? %>
              <%= @blog_post.body %>
            <% else %>
              <p class="text-muted fst-italic">No content yet.</p>
            <% end %>
          </div>

          <%# Tags %>
          <% if @blog_post.tags.any? %>
            <div class="blog-show-tags">
              <% @blog_post.tags.order(:name).each do |tag| %>
                <%= link_to blog_posts_path(tag_ids: [tag.id]),
                      class: "blog-show-tag-pill" do %>
                  <%= tag.name %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </article>

        <%# ===== RELATED POSTS ===== %>
        <% if @related_posts.any? %>
          <section class="blog-related">
            <h2 class="blog-related-title">Related posts</h2>
            <div class="row row-cols-1 row-cols-md-3 g-4">
              <% @related_posts.each do |post| %>
                <div class="col">
                  <article class="card blog-card h-100">
                    <%= link_to post, class: "blog-card-img-link" do %>
                      <div class="position-relative overflow-hidden blog-card-img-top">
                        <div class="ratio ratio-16x9">
                          <% if post.featured_image.attached? %>
                            <%= image_tag post.featured_image, alt: post.title, class: "object-fit-cover blog-card-image" %>
                          <% elsif post.image_url.present? %>
                            <img src="<%= post.image_url %>" alt="<%= post.title %>" class="object-fit-cover blog-card-image">
                          <% else %>
                            <div class="blog-card-placeholder d-flex align-items-center justify-content-center">
                              <i class="fa-solid fa-newspaper blog-card-placeholder-icon"></i>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                    <div class="card-body d-flex flex-column">
                      <div class="blog-card-meta">
                        <i class="fa-regular fa-calendar me-1"></i>
                        <%= post.created_at.strftime("%b %-d, %Y") %>
                        &nbsp;·
                        <i class="fa-regular fa-clock me-1"></i><%= post.reading_time %>
                      </div>
                      <h3 class="blog-card-title">
                        <%= link_to post.title, post, class: "blog-card-title-link" %>
                      </h3>
                      <% if post.blog_excerpt.present? %>
                        <p class="blog-card-excerpt"><%= post.blog_excerpt %></p>
                      <% end %>
                      <div class="blog-card-footer mt-auto">
                        <%= link_to "Read more", post, class: "blog-card-read-more" %>
                      </div>
                    </div>
                  </article>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <%# ===== ADMIN ACTIONS ===== %>
        <% if user_signed_in? %>
          <div class="blog-show-actions">

            <%# Status actions %>
            <% if @blog_post.draft? %>
              <%= button_to "Publish now",
                    publish_blog_post_path(@blog_post),
                    method: :patch,
                    data: { turbo_confirm: "Publish this post? It will be visible to everyone immediately." },
                    class: "btn btn-blog-publish btn-sm" %>

              <button type="button" class="btn btn-blog-schedule btn-sm"
                      data-bs-toggle="modal" data-bs-target="#scheduleModal">
                Schedule
              </button>
            <% end %>

            <% if @blog_post.scheduled? %>
              <button type="button" class="btn btn-blog-publish btn-sm"
                      data-bs-toggle="modal" data-bs-target="#publishNowModal">
                Publish now
              </button>
            <% end %>

            <% if @blog_post.draft? || @blog_post.scheduled? %>
              <span class="blog-show-actions-divider"></span>
            <% end %>

            <%# Edit / AI Revise %>
            <%= link_to "Edit", edit_blog_post_path(@blog_post), class: "btn btn-resource-edit btn-sm" %>

            <% if @blog_post.body.present? && @blog_post.blog_post_erb_content.blank? %>
              <button type="button" class="btn btn-blog-ai btn-sm"
                      data-bs-toggle="modal" data-bs-target="#aiReviseWarningModal">
                ✨ Revise with AI
              </button>
            <% else %>
              <%= link_to "✨ Revise with AI", ai_revise_blog_post_path(@blog_post), class: "btn btn-blog-ai btn-sm" %>
            <% end %>

            <%= button_to "Delete", @blog_post,
                  method: :delete,
                  class: "btn btn-resource-delete btn-sm",
                  data: { turbo_confirm: "Delete this post? This cannot be undone." } %>
          </div>
        <% end %>

        <%# ===== MODALS ===== %>

        <%# Schedule modal (draft only) %>
        <% if user_signed_in? && @blog_post.draft? %>
          <div class="modal fade" id="scheduleModal" tabindex="-1" aria-labelledby="scheduleModalLabel" aria-hidden="true">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="scheduleModalLabel">Schedule post</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <%= form_with url: schedule_blog_post_path(@blog_post), method: :patch do |f| %>
                  <div class="modal-body">
                    <p class="text-muted mb-3">Choose when this post will go live.</p>
                    <div class="mb-3">
                      <%= f.label :scheduled_at, "Publish at", class: "form-label fw-semibold" %>
                      <%= f.datetime_local_field :scheduled_at,
                            class: "form-control",
                            min: Time.current.strftime("%Y-%m-%dT%H:%M"),
                            required: true %>
                      <div class="form-text"><i class="fa-solid fa-clock me-1"></i>Times are in <strong><%= Time.current.zone %></strong> (Sydney).</div>
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Cancel</button>
                    <%= f.submit "Schedule post", class: "btn btn-blog-publish" %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <%# Publish now + edit schedule modals (scheduled only) %>
        <% if user_signed_in? && @blog_post.scheduled? %>
          <div class="modal fade" id="publishNowModal" tabindex="-1" aria-labelledby="publishNowModalLabel" aria-hidden="true">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="publishNowModalLabel">Publish now?</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                  <p>Scheduled for <strong><%= @blog_post.scheduled_at.strftime("%d %b %Y at %H:%M") %></strong>.</p>
                  <p class="mb-0">Publishing now will <strong>cancel that schedule</strong> and make the post live immediately.</p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Keep schedule</button>
                  <%= form_with url: publish_blog_post_path(@blog_post), method: :patch do |f| %>
                    <%= f.submit "Publish now", class: "btn btn-blog-publish" %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="modal fade" id="editScheduleModal" tabindex="-1" aria-labelledby="editScheduleModalLabel" aria-hidden="true">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="editScheduleModalLabel">Edit scheduled post</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <%# Form wraps only the body so the revert button_to doesn't nest inside it %>
                <%= form_with url: schedule_blog_post_path(@blog_post), method: :patch, id: "edit-schedule-form" do |f| %>
                  <div class="modal-body">
                    <div class="mb-3">
                      <%= f.label :scheduled_at, "Publish at", class: "form-label fw-semibold" %>
                      <%= f.datetime_local_field :scheduled_at,
                            class: "form-control",
                            value: @blog_post.scheduled_at.strftime("%Y-%m-%dT%H:%M"),
                            min: Time.current.strftime("%Y-%m-%dT%H:%M"),
                            required: true %>
                      <div class="form-text"><i class="fa-solid fa-clock me-1"></i>Times are in <strong><%= Time.current.zone %></strong> (Sydney).</div>
                    </div>
                  </div>
                <% end %>
                <div class="modal-footer d-flex justify-content-between align-items-center">
                  <%= button_to "Revert to draft",
                        cancel_schedule_blog_post_path(@blog_post),
                        method: :patch,
                        class: "btn btn-resource-edit",
                        form: { class: "m-0" } %>
                  <div class="d-flex gap-2">
                    <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="edit-schedule-form" class="btn btn-blog-publish">Update schedule</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <%# AI revision warning modal (manual posts) %>
        <% if user_signed_in? && @blog_post.body.present? && @blog_post.blog_post_erb_content.blank? %>
          <div class="modal fade" id="aiReviseWarningModal" tabindex="-1" aria-labelledby="aiReviseWarningModalLabel" aria-hidden="true">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">

                  <h5 class="modal-title" id="aiReviseWarningModalLabel"><i class="fa-solid fa-triangle-exclamation text-warning"></i> Before you continue</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                  <p>
                    This post was written manually using the rich text editor.
                  </p>
                  <p>
                    If you revise it with AI, the content will be permanently replaced with AI-generated HTML. After this, you won't be able to edit it in the rich text editor anymore. You can still edit the raw HTML directly, or keep revising with AI.
                  </p>
                  <p class="mb-0">
                    The AI will use your current content as its starting point.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-resource-edit" data-bs-dismiss="modal">Cancel</button>
                  <%= link_to "Continue to AI Revision", ai_revise_blog_post_path(@blog_post), class: "btn btn-blog-publish" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

      </div>

      <%# Sticky TOC sidebar — revealed by toc_controller.js when 2+ headings found %>
      <aside class="col-lg-3 d-none" data-toc-target="sidebar">
        <div class="blog-toc-sticky">
          <p class="blog-toc-label">In this post</p>
          <ul class="blog-toc-list" data-toc-target="list"></ul>
        </div>
      </aside>

    </div>
  </div>
</div>
