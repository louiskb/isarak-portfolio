<% content_for :title, "Create blog post with AI" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Blog", blog_posts_path %></li>
          <li class="breadcrumb-item active" aria-current="page">Create with AI</li>
        </ol>
      </nav>

      <div class="mb-5">
        <h1 class="mb-2"><i class="fa-solid fa-wand-magic-sparkles text-primary me-2"></i>Create with AI</h1>
        <p class="text-muted mb-4">
          Describe what you'd like to write about and the AI will draft a full post —
          review and edit it before publishing.
        </p>
        <%= link_to "Write manually instead", new_blog_post_path, class: "btn btn-blog-ai btn-sm" %>
      </div>

      <% if flash[:alert] %>
        <div class="alert alert-danger mb-4"><%= flash[:alert] %></div>
      <% end %>

      <%= simple_form_for :blog_post, url: create_with_ai_blog_posts_path, method: :post,
            html: { multipart: true,
                    data: { controller: "publish-form load-button" } } do |f| %>

        <div class="mb-5">
          <%= f.label :featured_image, "Featured image", class: "form-label" %>
          <%= f.file_field :featured_image, class: "form-control", accept: "image/*" %>
          <div class="form-text">Leave blank and the AI will find a relevant photo automatically.</div>
        </div>

        <div class="mb-5">
          <%= f.label :prompt, "What should the post be about?", class: "form-label" %>
          <%= f.text_area :prompt,
                value: @prompt,
                rows: 6,
                class: "form-control",
                placeholder: "e.g. \"Write a post about the impact of Gold Coast Airport on cross-border regional planning\"" %>
          <div class="form-text">Be as specific or as broad as you like — the AI will handle the rest.</div>
        </div>

        <%# Hidden fields — controlled by the split button via the publish-form Stimulus controller %>
        <input type="hidden"
               name="blog_post[status]"
               value="draft"
               data-publish-form-target="statusInput">
        <input type="hidden"
               name="blog_post[scheduled_at]"
               value=""
               data-publish-form-target="scheduledAtInput">

        <%# ===== SPLIT PUBLISH BUTTON ===== %>
        <div class="d-flex align-items-center gap-3 flex-wrap" data-load-button-target="buttons">
          <div class="btn-group dropup">

            <%# Default: generate and save as draft %>
            <button type="button" class="btn btn-primary btn-sm btn-publish-main"
                    data-action="click->load-button#loader click->publish-form#saveDraft"
                    data-load-button-loading-text-value="Generating your post...">
              Generate and save as draft
            </button>

            <%# Chevron — opens upward dropdown %>
            <button type="button"
                    class="btn btn-primary btn-sm btn-publish-chevron dropdown-toggle dropdown-toggle-split"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
              <span class="visually-hidden">More publishing options</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <button type="button" class="dropdown-item"
                        data-action="click->load-button#loader click->publish-form#publishNow"
                        data-load-button-loading-text-value="Generating and publishing...">
                  <i class="fa-solid fa-globe me-2 text-muted"></i>Generate and publish now
                </button>
              </li>
              <li>
                <button type="button" class="dropdown-item"
                        data-bs-toggle="modal" data-bs-target="#schedulePostModal">
                  <i class="fa-regular fa-clock me-2 text-muted"></i>Generate and schedule&hellip;
                </button>
              </li>
            </ul>
          </div>
        </div>

        <%# ===== SCHEDULE MODAL ===== %>
        <div class="modal fade" id="schedulePostModal" tabindex="-1"
             aria-labelledby="schedulePostModalLabel" aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="schedulePostModalLabel">
                  <i class="fa-regular fa-clock me-2"></i>Schedule post
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <p class="text-muted mb-3">
                  The AI will generate the post, then schedule it to go live at the time you choose.
                </p>
                <label class="form-label fw-semibold" for="schedule-post-datetime">Publish at</label>
                <input type="datetime-local"
                       id="schedule-post-datetime"
                       class="form-control"
                       min="<%= Time.current.strftime("%Y-%m-%dT%H:%M") %>"
                       data-publish-form-target="scheduleInput"
                       required>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary"
                        data-action="click->load-button#loader click->publish-form#confirmSchedule"
                        data-load-button-loading-text-value="Generating your post...">
                  Generate and schedule
                </button>
              </div>
            </div>
          </div>
        </div>

      <% end %>

    </div>
  </div>
</div>
